{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "<YOUR_PROJECT_PATH>"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "gh",
      "args": [
        "mcp-server"
      ]
    },
    "supabase": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--supabase-access-token",
        "<YOUR_SUPABASE_ACCESS_TOKEN>",
        "--project-id",
        "<YOUR_SUPABASE_PROJECT_ID>"
      ]
    }
  }
}
